# Скопируйте в .env рядом с docker-compose.yml или укажите: docker compose --env-file docker-compose.example.env up --build

# Обязательно: путь на хосте к распакованной модели Vosk (латиница в пути предпочтительно)
# Пример Windows: VOSK_MODEL_HOST_PATH=C:/Models/vosk-model-small-ru-0.22
# Пример относительно репозитория:
VOSK_MODEL_HOST_PATH=./models/vosk-model-small-ru-0.22

# Необязательно: секрет JWT для продакшена
# SECRET_KEY=
