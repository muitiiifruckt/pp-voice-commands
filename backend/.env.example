# Секрет для JWT (в продакшене замените на длинную случайную строку)
SECRET_KEY=change-me-in-production-use-long-random-string

# Только имя папки или путь относительно каталога backend/ (рядом с app/, .env)
VOSK_MODEL=vosk-model-ru-0.42

# Абсолютный путь (латиница), перекрывает VOSK_MODEL — удобно, если модель в Downloads и т.п.
# VOSK_MODEL_PATH=C:/Users/you/Downloads/vosk-model-small-ru-0.22

# Необязательно: каталог для аудиофайлов (по умолчанию backend/storage/audio)
# AUDIO_DIR=C:/path/to/audio

# Для Docker обычно задаётся в compose: DATABASE_URL=sqlite:////app/data/app.db
